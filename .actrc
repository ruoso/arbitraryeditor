# Defaults for running .github/workflows/ci.yml locally with `act`.
# Build the runner image first:
#   docker build -t arbitraryeditor/act-runner:latest -f .github/act/runner.Dockerfile .github/act
# The orchestrator driver passes these flags explicitly (plus a ccache volume and
# a synthesized push event); this file covers manual runs.
-P ubuntu-latest=arbitraryeditor/act-runner:latest
--pull=false
--action-offline-mode
